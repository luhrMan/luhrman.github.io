{
  "name": "Sqyre Hugo site",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "forwardPorts": [1313],
  "portsAttributes": {
    "1313": {
      "label": "Hugo server",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "tamasfe.even-better-toml"
      ],
      "settings": {
        "files.associations": {
          "hugo.toml": "toml"
        }
      }
    }
  },
  "postCreateCommand": "chmod +x scripts/sync-from-sqyre.sh 2>/dev/null || true",
  "remoteUser": "vscode"
}
